{
  "name": "agwatch-cli",
  "version": "1.0.4",
  "description": "Terminal analytics CLI for AI coding agents, usage, costs, tokens, and providers",
  "type": "module",
  "bin": {
    "agwatch": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
